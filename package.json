{
  "type": "commonjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development node scripts/run-server.js",
    "build": "node scripts/build-server.js",
    "build-dev": "node scripts/build-dev.js",
    "build-test": "node scripts/build-test.js",
    "test": "cross-env NODE_ENV=test node scripts/build-test.js && npm run jasmine",
    "test-fail-fast": "cross-env NODE_ENV=test node scripts/build-test.js && npm run jasmine-fail-fast",
    "test-fast": "cross-env NODE_ENV=test node scripts/build-test.js --fast-build && npm run jasmine",
    "test-parallel": "cross-env NODE_ENV=test node scripts/build-test.js && npm run jasmine-parallel",
    "test-inspect": "cross-env NODE_ENV=test node scripts/build-test.js && npm run jasmine-inspect",
    "jasmine": "cross-env NODE_ENV=test node --enable-source-maps node_modules/jasmine/bin/jasmine --config=./jasmine.json --random=false",
    "jasmine-fail-fast": "cross-env NODE_ENV=test node --enable-source-maps node_modules/jasmine/bin/jasmine --config=./jasmine.json --random=false --fail-fast",
    "jasmine-parallel": "cross-env NODE_ENV=test node --enable-source-maps node_modules/jasmine/bin/jasmine --config=./jasmine.json --parallel=4 --random=true",
    "jasmine-inspect": "cross-env NODE_ENV=test node --enable-source-maps --inspect-brk node_modules/jasmine/bin/jasmine --config=./jasmine.json --random=false",
    "benchmark:simulation": "node scripts/benchmark-simulation-environment.js",
    "lint": "eslint --quiet",
    "lint-fix": "eslint --quiet --fix",
    "lint-verbose": "eslint",
    "get-cards": "node ./scripts/fetchdata.js",
    "validate-cards": "ts-node scripts/validateCards.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.758.0",
    "@aws-sdk/client-s3": "^3.933.0",
    "@aws-sdk/lib-dynamodb": "^3.758.0",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.8.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "axios": "^1.9.0",
    "axios-retry": "^4.5.0",
    "cli-progress": "^3.12.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.8.0",
    "eslint-plugin-jasmine": "^4.2.0",
    "express": "^4.21.0",
    "glob": "^13.0.6",
    "globals": "^15.9.0",
    "jasmine": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mkdirp": "^3.0.1",
    "obscenity": "^0.4.3",
    "seedrandom": "^3.0.5",
    "socket.io": "^4.7.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.1",
    "underscore": "^1.13.6",
    "uuid": "^14.0.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/eslint__js": "^8.42.3",
    "@types/jasmine": "^5.1.4",
    "@types/node": "^20.19.11",
    "@types/underscore": "^1.11.15",
    "concurrently": "^9.1.0",
    "cpy-cli": "^5.0.0",
    "cross-env": "^10.0.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import-x": "^4.6.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "ts-node": "^10.9.2",
    "ts-to-zod": "^3.15.0"
  }
}
